<div class="news">
  {% if site.news != blank %}
    {% assign news = site.news | reverse %}
    {% if include.limit and page.announcements.limit %}
      {% assign news_limit = page.announcements.limit %}
    {% else %}
      {% assign news_limit = site.news | size %}
    {% endif %}
    <div class="news-scroll">
      {% for item in news limit: news_limit %}
        <div class="news-card">
          {% assign news_image = nil %}
          {% if item.image %}
            {% if item.image contains '/' %}
              {% assign news_image = item.image %}
            {% else %}
              {% assign news_image = item.image | prepend: '/assets/img/' %}
            {% endif %}
          {% elsif item.content contains '<img' %}
            {% assign image_block = item.content | split: '<img' | last %}
            {% if image_block contains 'src="' %}
              {% assign news_image = image_block | split: 'src="' | last | split: '"' | first %}
            {% elsif image_block contains "src='" %}
              {% assign news_image = image_block | split: "src='" | last | split: "'" | first %}
            {% endif %}
          {% endif %}
          {% if news_image %}
            <div class="news-card-img">
              {% if news_image contains '://' or news_image contains 'data:' %}
                <img src="{{ news_image }}" alt="{{ item.title | default: 'News' }}" loading="lazy">
              {% else %}
                <img src="{{ news_image | relative_url }}" alt="{{ item.title | default: 'News' }}" loading="lazy">
              {% endif %}
            </div>
          {% endif %}
          <div class="news-card-body">
            <span class="news-card-date">{{ item.date | date: '%b %d, %Y' }}</span>
            {% if item.inline %}
              <p class="news-card-text">{{ item.content | remove: '<p>' | remove: '</p>' | emojify }}</p>
            {% else %}
              <a class="news-card-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% assign plain = item.content | strip_html | strip_newlines | truncate: 120 %}
              {% if plain != blank %}
                <p class="news-card-text">{{ plain }}</p>
              {% endif %}
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
