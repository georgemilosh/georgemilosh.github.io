<div class="news">
  {% if page.latest_posts != blank %}
    {% assign latest_posts = site.posts %}
    {% if page.latest_posts.limit %}
      {% assign latest_posts_limit = page.latest_posts.limit %}
    {% else %}
      {% assign latest_posts_limit = site.posts | size %}
    {% endif %}
    <div class="news-scroll">
      {% for item in latest_posts limit: latest_posts_limit %}
        <div class="news-card">
          {% if item.image %}
            <div class="news-card-img">
              <img src="{{ item.image | relative_url }}" alt="{{ item.title }}" loading="lazy">
            </div>
          {% endif %}
          <div class="news-card-body">
            <span class="news-card-date">{{ item.date | date: '%b %d, %Y' }}</span>
            {% if item.redirect == blank %}
              <a class="news-card-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
            {% elsif item.redirect contains '://' %}
              <a class="news-card-title" href="{{ item.redirect }}" target="_blank">{{ item.title }}</a>
            {% else %}
              <a class="news-card-title" href="{{ item.redirect | relative_url }}">{{ item.title }}</a>
            {% endif %}
            {% assign plain = item.content | strip_html | strip_newlines | truncate: 120 %}
            {% if plain != blank %}
              <p class="news-card-text">{{ plain }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p>No posts so far...</p>
  {% endif %}
</div>
